{
  "name": "gentrix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "all": "npm run test && npm run build",
    "all:strict": "npm run lint && npm run test && npm run build",
    "dev": "next dev --webpack --hostname localhost",
    "dev:with-booking-spa": "npm run build:booking-app && npm run dev",
    "dev:lan": "next dev --webpack",
    "dev:turbo": "next dev --turbopack --hostname localhost",
    "build:booking-app": "npm install --include=dev --prefix frontends/booking && npm run build --prefix frontends/booking",
    "build": "npm run build:booking-app && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs",
    "db:migrate": "node scripts/apply-supabase-migrations.mjs",
    "db:clear-clients": "node scripts/run-clear-client-sites.mjs",
    "remotion:studio": "remotion studio remotion/index.ts",
    "remotion:render": "remotion render remotion/index.ts StudioPromo out/remotion/studio-promo.mp4",
    "remotion:render:still": "remotion still remotion/index.ts StudioPromo out/remotion/poster.png --frame=120",
    "faq:pdf": "node scripts/build-faq-pdf.mjs",
    "fonts:sync-inter": "node scripts/sync-studio-inter-fonts.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@date-fns/tz": "^1.4.1",
    "@remotion/cli": "^4.0.446",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tailwindcss/cli": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.18.2",
    "isomorphic-dompurify": "^3.7.1",
    "jsonrepair": "^3.13.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.51.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "^4.0.446",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "browserslist": {
    "production": [
      "chrome >= 109",
      "edge >= 109",
      "firefox >= 115",
      "safari >= 16.4"
    ],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  },
  "overrides": {
    "jsdom": "25.0.1"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.5",
    "@remotion/eslint-plugin": "^4.0.446",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "pg": "^8.14.1",
    "sharp": "^0.34.5",
    "supabase": "^2.92.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
