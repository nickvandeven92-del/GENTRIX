# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Publieke site-host(s) van jouw studio (geen custom-domain rewrite). Voorbeeld: jouw Vercel-domein of eigen merk-domein.
# NEXT_PUBLIC_PRIMARY_HOST=www.jouwstudio.nl
# Optioneel: extra hosts (komma-gescheiden), zelfde project
# NEXT_PUBLIC_PRIMARY_HOST_ALIASES=jouwstudio.nl,app.jouwstudio.nl

# Klantportaal op eigen hostnaam (CNAME naar dezelfde Vercel-deployment). Middleware rewrite → /portal/…
# NEXT_PUBLIC_PORTAL_HOST=portal.jouwstudio.nl

# Landingspagina op `/` (zelfde SSR als `/site/{slug}`):
# - Niet gezet: op NEXT_PUBLIC_PRIMARY_HOST (+ aliases) standaard slug `home` (generator “eigen homepage”). Anders: vaste showroom op `/`.
# - Vaste slug (ook op previews / andere hosts): LANDING_SITE_ROOT_SLUG=gentrix
# - Showroom op studio-domein houden: LANDING_SITE_ROOT_SLUG=off
# LANDING_SITE_ROOT_SLUG=

# Publieke landingspagina (showroom): contactlink
# NEXT_PUBLIC_STUDIO_CONTACT_EMAIL=studio@voorbeeld.nl
# Flyer / concept-preview CTA’s (voorkeur boven mailto): Cal.com, Calendly, Typeform, …
# NEXT_PUBLIC_STUDIO_MEETING_URL=https://cal.com/jouwstudio/kennismaking
# NEXT_PUBLIC_STUDIO_QUOTE_URL=https://forms.gle/…

# Optioneel: product-catalogus iframe op /winkel/{slug} (webshop_enabled aan). {slug} = zelfde waarde als studio-subfolder_slug
# (Chameleon-publieke route is meestal /shop/c/{slug} op je gedeployde shop-app).
# NEXT_PUBLIC_WEBSHOP_IFRAME_SRC_TEMPLATE=https://jouw-chameleon-app.example/shop/c/{slug}

# Shop-sync (Chameleon): standaard dezelfde DB als hierboven — vul NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY;
# KAMELEON_* is alleen nodig bij een tweede Supabase-project. Zie docs/WEBSHOP_TENANT_SYNC.md
# KAMELEON_SUPABASE_URL=
# KAMELEON_SUPABASE_SERVICE_ROLE_KEY=
# (alias) CHAMELEON_SUPABASE_URL=
# (alias) CHAMELEON_SUPABASE_SERVICE_ROLE_KEY=

# Claude (Anthropic Console — server-only, niet in client bundle)
# Bestand .env.local hoort in dezelfde map als package.json (projectroot gentrix).
# Geen # voor de key-regel; na wijziging: dev-server opnieuw starten.
ANTHROPIC_API_KEY=
# Model voor support-calls (self-review, design rationale, edit, chat, commands).
# Standaard: claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Site-generatie: tweede Claude-pass (QA op HTML/JSON). Standaard UIT (minder stream-timeouts).
# Aanzetten: ENABLE_SITE_SELF_REVIEW=1 (of true/yes). Force uit: DISABLE_SITE_SELF_REVIEW=1 (wint altijd).
# ENABLE_SITE_SELF_REVIEW=1
# DISABLE_SITE_SELF_REVIEW=1

# Model voor de site-generatie zelf (streaming, creatief werk).
# Standaard: claude-sonnet-4-6 (kosten beperkt; zelfde default als ANTHROPIC_MODEL).
# Optioneel duurder/krachtiger: claude-opus-4-6 (of oudere opus-snapshot) via ANTHROPIC_GENERATE_MODEL.
# ANTHROPIC_GENERATE_MODEL=claude-sonnet-4-6

# Minimale user-prompt bij site-generatie: geen branche-/designtaal-/variatieblokken (wel CONTENT AUTHORITY + studio-contract + JSON-schema).
# Zet op 1, true of yes. Of: `minimalPrompt: true` meegeven aan de server-call (zelfde effect).
# SITE_GENERATION_MINIMAL_PROMPT=1

# (Gearchiveerd: interpretatie-envvars verwijderd na AI engine reset)

# Premium SVG-logo-pipeline: extra Claude-call vóór site-generatie (brand DNA → 3 specs → score → render).
# Zet op 1 om te activeren. Kost tokens; bij fout gaat generatie door zonder logoSet.
# ENABLE_BRAND_LOGO_SYSTEM=1
# Optioneel: apart model voor logo-JSON (default = ANTHROPIC_MODEL of sonnet)
# ANTHROPIC_LOGO_MODEL=claude-sonnet-4-6

# Optioneel: kosten-schatting in /admin/portal (USD per miljoen tokens; pas aan naar huidige Anthropic-prijzen)
# ANTHROPIC_PRICE_INPUT_PER_MTOK_USD=3
# ANTHROPIC_PRICE_OUTPUT_PER_MTOK_USD=15
# ANTHROPIC_PRICE_CACHE_READ_PER_MTOK_USD=0.3
# ANTHROPIC_PRICE_CACHE_WRITE_PER_MTOK_USD=3.75
# Eigen maand-plafond voor waarschuwing (USD)
# ANTHROPIC_MONTHLY_BUDGET_USD=50
# Grof euro-hint op het portaal: koers USD→EUR
# ANTHROPIC_EUR_PER_USD=0.92

# Unsplash API (server-only): vervangt gehallucineerde foto-URL's door echte zoekresultaten (alt-tekst + stukje briefing).
# Plak je **Access Key** uit https://unsplash.com/oauth/applications (header: Client-ID). Secret key en application id zijn hier niet nodig.
# Gratis: 50 req/uur (demo), 5000 req/uur (productie).
# Zonder key: afbeeldingen worden niet vervangen (graceful degradation).
# UNSPLASH_ACCESS_KEY=

# Promo-video (Playwright): zet op 0 om uit te schakelen (bijv. serverless zonder Chromium).
# STUDIO_PROMO_VIDEO=0

# KVK Handelsregister API (server-only — nooit naar de client)
# Documentatie: https://developers.kvk.nl/
# KVK_API_KEY=
# Optioneel; standaard https://api.kvk.nl (productie).
# Test (eigen certificaatketen): KVK_API_BASE_URL=https://api.kvk.nl/test
# KVK_API_BASE_URL=https://api.kvk.nl
# Timeout per upstream-request in ms (default 20000)
# KVK_API_TIMEOUT_MS=20000

# Transactionele e-mail (Resend — afsprakenbevestiging + .ics-bijlage)
# https://resend.com/api-keys — domein voor "from" verifiëren in Resend-dashboard.
# RESEND_API_KEY=re_...
# Optioneel; default = "GENTRIX <onboarding@resend.dev>" (alleen bruikbaar binnen Resend-testlimieten)
# RESEND_FROM="Jouw Studio <notificaties@jouwdomein.nl>"

# Optioneel: migraties lokaal (npm run db:migrate). Supabase → Connect.
# Bij ETIMEDOUT / IPv6-thuisnetwerk: gebruik "Session pooler" (niet "Direct") — host aws-0-….pooler.supabase.com,
# user postgres.<project-ref>, poort 5432. Zie Supabase docs "Pooler session mode".
# Methode A — volledige URI:
# DATABASE_URL=postgresql://postgres:JOUW_WACHTWOORD@db.xxxxx.supabase.co:5432/postgres
# Session pooler (IPv4-vriendelijk), voorbeeld:
# DATABASE_URL=postgresql://postgres.xxxxx:JOUW_WACHTWOORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
# Methode B — wachtwoord plat (aanbevolen bij @ # % : in wachtwoord):
# SUPABASE_DB_HOST=db.xxxxx.supabase.co
# SUPABASE_DB_PASSWORD=plat_wachtwoord_zonder_aanhalingstekens
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres

# Server-only: opslaan vanuit /generator (API /api/clients). Nooit committen.
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Klantportaal — toegang (server)
# In productie: strikte modus standaard AAN (alleen gekoppelde klant + optioneel studio-UUID’s).
# PORTAL_STRICT_ACCESS=0   — strikte modus uit (ook in productie; alleen voor debug)
# PORTAL_STRICT_ACCESS=1   — strikte modus aan (ook in development)
# Komma-gescheiden Supabase Auth user-UUID’s die álle portalen mogen openen + /api/portal/* (studio/support).
# PORTAL_STUDIO_PREVIEW_USER_IDS=uuid1,uuid2
# PORTAL_HIDE_STUDIO_PREVIEW_BANNER=1  — geen amber balk in portaal-UI

# Publieke basis-URL (uitnodigingsmails, factuurmail, Supabase redirect); in productie bijna altijd verplicht.
# NEXT_PUBLIC_SITE_URL=https://jouw-studio.nl

# Vercel Cron: dagelijkse afspraak-herinneringen (Authorization: Bearer …). Genereer een lange random string.
# CRON_SECRET=

# Web Push — browsermelding bij nieuwe afspraak (klantportaal, ook als tabblad dicht is).
# Genereer keys: npx web-push generate-vapid-keys
# Publieke key mag naar de client (Next bundelt NEXT_PUBLIC_*).
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# mailto: of https:-URL (vereist door specificatie), bijv. mailto:factuur@jouwdomein.nl
# VAPID_SUBJECT=mailto:factuur@jouwdomein.nl

