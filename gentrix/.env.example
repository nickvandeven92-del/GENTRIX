# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Eerstepartij /site analytics (POST /api/analytics/events; tabel `site_analytics_events`). 0 = geen client-tracker.
# NEXT_PUBLIC_GENTRIX_FIRST_PARTY_ANALYTICS=1
# API rate limit (in-memory per instance; productie: edge/WAF/Redis). Standaard 120 req / 10 min per IP.
# ANALYTICS_INGEST_MAX_REQUESTS_PER_IP_WINDOW=120
# ANALYTICS_INGEST_WINDOW_MS=600000

# Publieke site-host(s) van jouw studio (geen custom-domain rewrite). Voorbeeld: jouw Vercel-domein of eigen merk-domein.
# NEXT_PUBLIC_PRIMARY_HOST=www.jouwstudio.nl
# Optioneel: extra hosts (komma-gescheiden), zelfde project
# NEXT_PUBLIC_PRIMARY_HOST_ALIASES=jouwstudio.nl,app.jouwstudio.nl

# Klantportaal op eigen hostnaam (CNAME naar dezelfde Vercel-deployment). Middleware rewrite → /portal/…
# NEXT_PUBLIC_PORTAL_HOST=portal.jouwstudio.nl

# Landingspagina op `/` (zelfde SSR als `/site/{slug}`):
# - Niet gezet: op NEXT_PUBLIC_PRIMARY_HOST (+ aliases) standaard slug `home` (generator “eigen homepage”). Anders: vaste showroom op `/`.
# - Vaste slug (ook op previews / andere hosts): LANDING_SITE_ROOT_SLUG=gentrix
# - Showroom op studio-domein houden: LANDING_SITE_ROOT_SLUG=off
# LANDING_SITE_ROOT_SLUG=

# Publiek zichtbaar merk (showroom-header, login, tabtitel-default, concept-actiebalk). Standaard in code: Gentrix.
# NEXT_PUBLIC_PUBLIC_BRAND=Gentrix

# Publieke landingspagina (showroom): contactlink
# NEXT_PUBLIC_STUDIO_CONTACT_EMAIL=studio@voorbeeld.nl
# Flyer / concept-preview CTA’s (zwevende knoppen + laatste rondleidingsstap; voorkeur boven mailto): Cal.com, Stripe Payment Link, …
# NEXT_PUBLIC_STUDIO_MEETING_URL=https://cal.com/jouwstudio/kennismaking
# Optioneel: externe betaalpagina (Stripe Payment Link e.d.) i.p.v. ingebouwd /site/{slug}/bestellen
# NEXT_PUBLIC_STUDIO_CHECKOUT_URL=https://buy.stripe.com/…
# Offerte-/intake-URL (los van bestellen; voor studio-links)
# NEXT_PUBLIC_STUDIO_QUOTE_URL=https://forms.gle/…

# Optioneel: product-catalogus iframe op /winkel/{slug} (webshop_enabled aan). {slug} = zelfde waarde als studio-subfolder_slug
# (Chameleon-publieke route is meestal /shop/c/{slug} op je gedeployde shop-app).
# NEXT_PUBLIC_WEBSHOP_IFRAME_SRC_TEMPLATE=https://jouw-chameleon-app.example/shop/c/{slug}

# Standaard: `/boek/{slug}` → ingebouwde Vite-SPA onder `/booking-app/` (zie `npm run build`, `public/booking-app/`).
# Aparte Vite-host (zeldzaam): CORS op de publieke boek-API’s.
# BOOKING_VITE_PUBLIC_ORIGINS=https://externe-spa.example

# Shop-sync (Chameleon): standaard dezelfde DB als hierboven — vul NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY;
# KAMELEON_* is alleen nodig bij een tweede Supabase-project. Zie docs/WEBSHOP_TENANT_SYNC.md
# KAMELEON_SUPABASE_URL=
# KAMELEON_SUPABASE_SERVICE_ROLE_KEY=
# (alias) CHAMELEON_SUPABASE_URL=
# (alias) CHAMELEON_SUPABASE_SERVICE_ROLE_KEY=

# Claude (Anthropic Console — server-only, niet in client bundle)
# Bestand .env.local hoort in dezelfde map als package.json (projectroot gentrix).
# Geen # voor de key-regel; na wijziging: dev-server opnieuw starten.
ANTHROPIC_API_KEY=
# Globaal model (o.a. edit-site, chat, commands): default sonnet in die modules.
# ANTHROPIC_MODEL=claude-sonnet-4-6
#
# Site-generatie (studio): generate/support-modellen, max_tokens, minimale prompt-default, Denklijn/vision
# staan vast in lib/ai/studio-generation-fixed-config.ts. Self-review (tweede Sonnet-pass) optioneel:
# STUDIO_SELF_REVIEW=1

# Site-studio — transport (runtime, **geen** frontend-rebuild nodig op Vercel):
# `jobs` = server-job + polling (standaard). `stream` = lange NDJSON naar de browser.
# SITE_GENERATION_TRANSPORT=jobs
# SITE_GENERATION_TRANSPORT=stream
#
# Gefaseerde async job (twee serverless-invocaties; reset Vercel wall-clock na compositie):
# `SITE_GENERATION_PHASED_JOB=1` + migratie `site_generation_jobs` (generation_checkpoint, generation_split_phase).
# `INTERNAL_SITE_GEN_JOB_CONTINUE_SECRET` = sterk geheim; server roept `POST /api/generate-site/jobs/{id}/continue` aan.
# Publieke basis-URL voor die fetch: `NEXT_PUBLIC_SITE_URL` (productie) of `VERCEL_URL` op Vercel.
# SITE_GENERATION_PHASED_JOB=1
# INTERNAL_SITE_GEN_JOB_CONTINUE_SECRET=
# Legacy (wordt bij **build** in de client ingevuld; wijziging vereist vaak redeploy):
# NEXT_PUBLIC_SITE_GENERATION_USE_STREAM=1

# (Gearchiveerd: interpretatie-envvars verwijderd na AI engine reset)

# Premium SVG-logo-pipeline: extra Claude-call vóór site-generatie (brand DNA → 3 specs → score → render).
# Zet op 1 om te activeren. Kost tokens; bij fout gaat generatie door zonder logoSet.
# ENABLE_BRAND_LOGO_SYSTEM=1
# Optioneel: apart model voor logo-JSON (default = ANTHROPIC_MODEL of sonnet)
# ANTHROPIC_LOGO_MODEL=claude-sonnet-4-6

# Optioneel: kosten-schatting in /admin/portal (USD per miljoen tokens; pas aan naar huidige Anthropic-prijzen)
# ANTHROPIC_PRICE_INPUT_PER_MTOK_USD=3
# ANTHROPIC_PRICE_OUTPUT_PER_MTOK_USD=15
# ANTHROPIC_PRICE_CACHE_READ_PER_MTOK_USD=0.3
# ANTHROPIC_PRICE_CACHE_WRITE_PER_MTOK_USD=3.75
# Eigen maand-plafond voor waarschuwing (USD)
# ANTHROPIC_MONTHLY_BUDGET_USD=50
# Grof euro-hint op het portaal: koers USD→EUR
# ANTHROPIC_EUR_PER_USD=0.92

# AI-hero (één sfeerbeeld in `#hero`, upload naar Supabase `site-assets`) — vereist NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.
#
# Primaire beeld-API: Google AI Studio (Gemini image) — key uit https://aistudio.google.com/apikey
# Zet de key in .env.local (zelfde map als package.json) en herstart `npm run dev` / redeploy.
# GOOGLE_AI_STUDIO_API=          # aanbevolen projectnaam
# GOOGLE_AI_STUDIO_API_KEY=      # zelfde key; veel gebruikers noemen de var zo na AI Studio
# GEMINI_API_KEY=                # alias (zoals in veel Google-voorbeelden)
# GOOGLE_GENERATIVE_AI_API_KEY=  # alias (o.a. Vercel AI SDK)
#
# OPENAI_API_KEY is niet nodig tenzij je expliciet DALL·E als fallback/provider wilt (`STUDIO_AI_HERO_IMAGE_PROVIDER=openai`).
# Bij provider `auto` (default): eerst Gemini, pas daarna OpenAI als die key wél staat.
#
# Model override (default `gemini-2.5-flash-image` — “Nano Banana”; nieuwere previews uit AI Studio hier zetten):
# STUDIO_AI_HERO_GEMINI_MODEL=gemini-2.5-flash-image
# Forceer één provider: auto | google | openai
# STUDIO_AI_HERO_IMAGE_PROVIDER=auto
# Uit: STUDIO_AI_HERO_IMAGE=0
# OPENAI_API_KEY=
# STUDIO_AI_HERO_IMAGE=0
#
# AI-merkmark (1:1 logo + PNG-favicon’s, zelfde Gemini/OpenAI + Supabase als hero). Uit: STUDIO_AI_BRAND_IMAGE=0
# STUDIO_AI_BRAND_IMAGE=0

# Promo-video (Playwright): zet op 0 om uit te schakelen (bijv. serverless zonder Chromium).
# STUDIO_PROMO_VIDEO=0

# KVK Handelsregister API (server-only — nooit naar de client)
# Documentatie: https://developers.kvk.nl/
# KVK_API_KEY=
# Optioneel; standaard https://api.kvk.nl (productie).
# Test (eigen certificaatketen): KVK_API_BASE_URL=https://api.kvk.nl/test
# KVK_API_BASE_URL=https://api.kvk.nl
# Timeout per upstream-request in ms (default 20000)
# KVK_API_TIMEOUT_MS=20000

# Transactionele e-mail (Resend — afspraken, welkom, factuur, wachtwoord-reset)
# https://resend.com/api-keys — domein voor "from" verifiëren in Resend-dashboard.
# RESEND_API_KEY=re_...
# Optioneel; default = "GENTRIX <onboarding@resend.dev>" (alleen bruikbaar binnen Resend-testlimieten)
# RESEND_FROM="GENTRIX <notificaties@jouwdomein.nl>"

# E-mail footer — adres + KVK voor alle transactionele mails
# EMAIL_FOOTER_ADDRESS="Gentrix · KVK 12345678 · Jouw Straat 1 · 1234 AB Amsterdam"

# Basis-URL voor unsubscribe-link in e-mail footer (optioneel; weglaten = geen unsubscribe-link)
# EMAIL_UNSUBSCRIBE_BASE_URL=https://jouw-studio.nl/uitschrijven

# Auth webhook secret — voor POST /api/webhooks/auth (welkom-email bij nieuw account)
# Genereer een veilige string: openssl rand -hex 32
# Configureer dezelfde waarde als webhook-secret in Supabase → Authentication → Hooks
# AUTH_WEBHOOK_SECRET=

# Optioneel: migraties lokaal (npm run db:migrate). Supabase → Connect.
# Bij ETIMEDOUT / IPv6-thuisnetwerk: gebruik "Session pooler" (niet "Direct") — host aws-0-….pooler.supabase.com,
# user postgres.<project-ref>, poort 5432. Zie Supabase docs "Pooler session mode".
# Methode A — volledige URI:
# DATABASE_URL=postgresql://postgres:JOUW_WACHTWOORD@db.xxxxx.supabase.co:5432/postgres
# Session pooler (IPv4-vriendelijk), voorbeeld:
# DATABASE_URL=postgresql://postgres.xxxxx:JOUW_WACHTWOORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
# Methode B — wachtwoord plat (aanbevolen bij @ # % : in wachtwoord):
# SUPABASE_DB_HOST=db.xxxxx.supabase.co
# SUPABASE_DB_PASSWORD=plat_wachtwoord_zonder_aanhalingstekens
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres

# Server-only: opslaan vanuit /generator (API /api/clients). Nooit committen.
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Klantportaal — toegang (server)
# In productie: strikte modus standaard AAN (alleen gekoppelde klant + optioneel studio-UUID’s).
# PORTAL_STRICT_ACCESS=0   — strikte modus uit (ook in productie; alleen voor debug)
# PORTAL_STRICT_ACCESS=1   — strikte modus aan (ook in development)
# Komma-gescheiden Supabase Auth user-UUID’s die álle portalen mogen openen + /api/portal/* (studio/support).
# PORTAL_STUDIO_PREVIEW_USER_IDS=uuid1,uuid2
# PORTAL_HIDE_STUDIO_PREVIEW_BANNER=1  — geen amber balk in portaal-UI

# Studio-admin — cross-tenant API's (/api/admin/*, /api/clients/*, /api/generate-site/*, /api/ai-*, /api/kvk/*, /api/upload/*).
# Alleen UUID's in deze lijst mogen willekeurige tenants muteren; fail-closed in productie.
# Vult `PORTAL_STUDIO_PREVIEW_USER_IDS` als default (zelfde semantiek), zet eigen waarde om strikter te scheiden.
# STUDIO_ADMIN_USER_IDS=uuid1,uuid2
# Expliciet forceren (0 = uit; 1 = aan; weggelaten = aan bij NODE_ENV=production):
# STUDIO_ADMIN_STRICT=1

# MFA cookie + OTP-hash signing secret — dedicated geheim (niet je service role key).
# Genereer: openssl rand -base64 48
# In productie verplicht; in dev valt de code terug op SUPABASE_SERVICE_ROLE_KEY.
# MFA_SIGNING_SECRET=

# Dev alleen: extra hostnames die Next 16 dev-mode mag accepteren voor /_next/*.
# NEXT_DEV_ALLOWED_ORIGINS=192.168.1.20,mijn-mac.local

# Publieke basis-URL (uitnodigingsmails, factuurmail, Supabase redirect); in productie bijna altijd verplicht.
# Ook gebruikt in flyer-PDF als er geen Host-header is (fallback). Zet dit gelijk aan je publieke studio-domein.
# NEXT_PUBLIC_SITE_URL=https://jouw-studio.nl

# Optioneel: link achter “GENTRIX” in de subtiele site-credit (rechtsonder in iframe + ZIP-export). Default https://gentrix.nl
# NEXT_PUBLIC_GENTRIX_CREDIT_URL=https://gentrix.nl

# Vercel Cron: dagelijkse afspraak-herinneringen (Authorization: Bearer …). Genereer een lange random string.
# CRON_SECRET=

# Social gallery (Meta Graph / OAuth)
# Gebruik een sterke geheime sleutel voor AES-GCM encryptie van klanttokens:
# openssl rand -base64 48
# SOCIAL_GALLERY_TOKEN_SECRET=
# META_APP_ID=
# META_APP_SECRET=
# Cron batch-limieten voor background sync (optioneel):
# SOCIAL_GALLERY_CRON_BATCH_SIZE=60
# SOCIAL_GALLERY_CRON_MAX_SYNCS=40

# Web Push — browsermelding bij nieuwe afspraak (klantportaal, ook als tabblad dicht is).
# Genereer keys: npx web-push generate-vapid-keys
# Publieke key mag naar de client (Next bundelt NEXT_PUBLIC_*).
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# mailto: of https:-URL (vereist door specificatie), bijv. mailto:factuur@jouwdomein.nl
# VAPID_SUBJECT=mailto:factuur@jouwdomein.nl

